# Environment variables for Patent Board Application
# Copy this file to .env and update with your actual values

# ============================================
# DATABASE CONFIGURATION
# ============================================

# MariaDB (Primary Database)
MARIADB_URL=mysql+aiomysql://patent_user:your_secure_password@localhost:3306/patent_db
MARIADB_HOST=localhost
MARIADB_PORT=3306
MARIADB_DATABASE=patent_db
MARIADB_USER=patent_user
MARIADB_PASSWORD=your_secure_password

# Neo4j (Graph Database)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=neo4j

# ============================================
# API CONFIGURATION
# ============================================

API_V1_STR=/api/v1
HOST=0.0.0.0
PORT=8001

# ============================================
# SECURITY CONFIGURATION
# ============================================

# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# AI/ML CONFIGURATION
# ============================================

# OpenAI API Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=4000
OPENAI_TEMPERATURE=0.7

# LangSmith for LangGraph tracing
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=patent-board

# ============================================
# MCP SERVER CONFIGURATION
# ============================================

MCP_SERVER_URL=http://localhost:8082
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8082

# ============================================
# INTEGRATION CONFIGURATION
# ============================================

# CORS Origins (comma-separated)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8001,http://127.0.0.1:3000,http://127.0.0.1:8001

# Frontend URLs
FRONTEND_URL=http://localhost:3000
FRONTEND_HOST=localhost
FRONTEND_PORT=3000

# ============================================
# OPTIONAL SERVICES
# ============================================

# Redis for caching (optional)
REDIS_URL=redis://localhost:6379/0

# Elasticsearch for advanced search (optional)
ELASTICSEARCH_URL=http://localhost:9200

# ============================================
# DEVELOPMENT SETTINGS
# ============================================

PROJECT_NAME=Patent Board
VERSION=1.0.0
DEBUG=true
DEVELOPMENT=true
ENVIRONMENT=development

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================
# PRODUCTION SETTINGS (uncomment for production)
# ============================================

# DEBUG=false
# DEVELOPMENT=false
# ENVIRONMENT=production
# LOG_LEVEL=WARNING

# Database pooling (production)
# DB_POOL_SIZE=20
# DB_MAX_OVERFLOW=30
# DB_POOL_TIMEOUT=30

# Rate limiting
# RATE_LIMIT_PER_MINUTE=60
# RATE_LIMIT_BURST=10