# Environment variables for Patent Board
# Copy this file to .env and update with your actual values

# Database Configuration
MARIADB_URL=mysql+aiomysql://scraper:Scraper123!@192.168.0.10/pa_system
MARIADB_HOST=192.168.0.10
MARIADB_PORT=3306
MARIADB_USER=scraper
MARIADB_PASSWORD=Scraper123!
MARIADB_DATABASE=pa_system
PA_SYSTEM_DB_URL=mysql+aiomysql://scraper:Scraper123!@192.168.0.10/pa_system
PA_SYSTEM_DB_HOST=192.168.0.10
PA_SYSTEM_DB_PORT=3306
PA_SYSTEM_DB_NAME=pa_system
PA_SYSTEM_DB_USER=scraper
PA_SYSTEM_DB_PASSWORD=Scraper123!

PATENTDB_URL=mysql+aiomysql://scraper:Scraper123!@192.168.0.10/patent_db
PATENTDB_HOST=192.168.0.10
PATENTDB_PORT=3306
PATENTDB_USER=scraper
PATENTDB_PASSWORD=Scraper123!
PATENTDB_DATABASE=patent_db

NEO4J_URI=neo4j://192.168.0.10:7688
# NEO4J_HOST=192.168.0.10
# NEO4J_PORT=7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=manhae428!
NEO4J_DATABASE=patentsKg

# OpenSearch Configuration (외부 서비스 접속)
OPENSEARCH_URL=http://192.168.0.10:9200
OPENSEARCH_HOST=192.168.0.10
OPENSEARCH_PORT=9200

# Redis Configuration
REDIS_URL=redis://localhost:6380

# API Configuration
API_V1_STR=/api/v1
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# OpenAI Configuration (for LangGraph)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000
OPENAI_TOP_P=1.0
OPENAI_FREQUENCY_PENALTY=0.0
OPENAI_PRESENCE_PENALTY=0.0

# LangGraph Configuration
MAX_CONVERSATION_LENGTH=1000
MAX_CONTEXT_TOKENS=4000
RESPONSE_TIMEOUT=30
CHECKPOINT_MEMORY_BACKEND=memory

# MCP Server Configuration
MCP_SERVER_URL=http://localhost:8082
MCP_TIMEOUT=30

# Chatbot Configuration
CHATBOT_DEFAULT_TEMPERATURE=0.7
CHATBOT_MAX_TOKENS=2000
CHATBOT_TOP_P=1.0
CHATBOT_CONTEXT_HISTORY_LIMIT=5
CHATBOT_PATENT_CONTEXT_LIMIT=3

# Context Engineering Configuration
USER_PATTERN_ANALYSIS_ENABLED=true
USER_PATTERN_KEYWORD_THRESHOLD=3
USER_PATTERN_PATENT_ID_THRESHOLD=1
USER_PATTERN_VERB_THRESHOLD=2

# URL Generation Configuration
URL_GENERATION_SOURCES=["google", "uspto", "kipris"]
URL_GENERATION_DEFAULT_COUNTRY=auto

# CORS Origins (comma-separated)
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8001", "http://localhost:48001", "http://localhost:48080", "http://localhost:48082", "http://localhost:48003", "http://greennuri.info:48001", "http://greennuri.info:48080"]

# App Configuration
PROJECT_NAME="Patent Board"
VERSION="1.0.0"
DEBUG=true

# LangSmith Configuration (for debugging)
LANGSMITH_API_KEY=your-langsmith-api-key-here

# Frontend
FRONTEND_URL=http://localhost:3000

# Production Ports
PROD_BACKEND_PORT=58001
PROD_FRONTEND_PORT=58080
PROD_MCP_PORT=58082
PROD_LANGGRAPH_PORT=58003

# Development Ports
DEV_BACKEND_PORT=48001
DEV_FRONTEND_PORT=48080
DEV_MCP_PORT=48082
DEV_LANGGRAPH_PORT=48003
DEV_REDIS_PORT=46379